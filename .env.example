# Copy this file to .env and change values for your environment.

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=System Admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_Immediately_123!

# Comma-separated allowed web origins.
CORS_ALLOW_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# 0 for HTTP, 1 for HTTPS.
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=lax

# Login brute-force protection
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=900
LOGIN_MAX_ATTEMPTS_USER_IP=5
LOGIN_MAX_ATTEMPTS_IP=20
