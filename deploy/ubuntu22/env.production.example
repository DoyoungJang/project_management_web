# Copy to /opt/project_management_web/shared/.env and edit values.

# Required: initial admin account
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_Immediately_123!

# CORS origins for browser access (comma-separated)
# Example (HTTP internal):
# CORS_ALLOW_ORIGINS=http://192.168.0.10,http://pm.internal.local
CORS_ALLOW_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Cookie security
# 0 for HTTP internal network, 1 for HTTPS
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=lax

# Login brute-force protection
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=900
LOGIN_MAX_ATTEMPTS_USER_IP=5
LOGIN_MAX_ATTEMPTS_IP=20

# Redis is installed for infra readiness (current app does not require it yet)
# REDIS_URL=redis://127.0.0.1:6379/0
